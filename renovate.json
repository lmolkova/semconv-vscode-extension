{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": ["config:recommended"],
  "dependencyDashboard": true,
  "minimumReleaseAge": "7 days",
  "internalChecksFilter": "strict",
  "osvVulnerabilityAlerts": true,
  "lockFileMaintenance": {
    "enabled": true,
    "schedule": ["before 5am on monday"]
  },
  "packageRules": [
    {
      "description": "Group non-major devDependency updates into one PR",
      "matchDepTypes": ["devDependencies"],
      "matchUpdateTypes": ["minor", "patch"],
      "groupName": "devDependencies (non-major)"
    },
    {
      "description": "Major updates require explicit approval from the dashboard",
      "matchUpdateTypes": ["major"],
      "dependencyDashboardApproval": true
    },
    {
      "description": "Keep the pinned pnpm version (packageManager) current",
      "matchDepTypes": ["packageManager"],
      "groupName": "pnpm"
    }
  ],
  "vulnerabilityAlerts": {
    "labels": ["security"],
    "minimumReleaseAge": null
  },
  "customManagers": [
    {
      "description": "Track the Weaver release the vendored semconv JSON schema is pinned to",
      "customType": "regex",
      "managerFilePatterns": ["/^scripts/weaver-version\\.mjs$/"],
      "matchStrings": [
        "datasource=(?<datasource>\\S+) depName=(?<depName>\\S+)\\s+export const WEAVER_VERSION = \"(?<currentValue>[^\"]+)\""
      ]
    }
  ]
}
